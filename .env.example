# Dev only — llama a MiniMax directamente (NO usar en producción)
# En prod usa el Cloudflare Worker (workers/) y esta variable NO se incluye en el build
VITE_MINIMAX_API_KEY=your_api_key_here

# Prod — URL del Cloudflare Worker que proxy a MiniMax
# Solo se necesita en el build de producción (GitHub Actions)
# VITE_CHAT_API_URL=https://minimax-proxy.tu-subdominio.workers.dev/api/chat
